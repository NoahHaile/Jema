# ----- Required -----

# Telegram bot token from @BotFather
BOT_TOKEN=

# OpenAI API key (https://platform.openai.com/api-keys)
OPENAI_API_KEY=

# ----- Optional -----

# Receipt VISION model — must be multimodal. gpt-4o-mini is among the cheapest. (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# Meme CAPTION model — text-only, cheap. Can be dropped to an even cheaper text model. (default: gpt-4o-mini)
OPENAI_CAPTION_MODEL=gpt-4o-mini

# Currency label shown for receipts when the amount's currency is unclear (default: KSh)
DEFAULT_CURRENCY=KSh

# ----- Roast meme engine -----

# The star of the memes (the user). (default: Noah)
PROTAGONIST=Noah

# The crew = roast victims. SET REAL NAMES HERE (comma-separated). Defaults are placeholders.
CREW_NAMES=Mike,LeBron,Kev

# Fraction of memes that are a clapback (crew roasts Noah / crew-vs-crew) vs Noah-on-top. (default: 0.25)
MEME_CLAPBACK_RATE=0.25

# Hard-pin the target group instead of auto-registering on add.
# Leave blank to let the bot register the group it's added to.
GROUP_CHAT_ID=

# IANA timezone for all scheduled jobs (default: Africa/Nairobi / EAT)
TIMEZONE=Africa/Nairobi

# ----- Schedule overrides (cron, evaluated in TIMEZONE) -----

# Weekly poll cycle: post (Mon) -> last-call reminder (Thu) -> close+announce (Fri)
POLL_CRON=0 9 * * 1          # Mon 09:00 — post the poll, start a fresh cycle
POLL_REMINDER_CRON=0 18 * * 4 # Thu 18:00 — "last call" nudge with current leader
POLL_CLOSE_CRON=0 9 * * 5     # Fri 09:00 — close, announce winner + who's in

# Scheduled poll content (POLL_OPTIONS is pipe-separated)
POLL_QUESTION=🏀 Which day works for this week's run?
POLL_OPTIONS=Sat morning|Sat evening|Sun morning|Sun evening|A weeknight

# Scheduled meme runs a few times a week (default: Mon/Wed/Fri 12:00)
MEME_CRON=0 12 * * 1,3,5

# Optional extra theme flavor (pipe-separated) folded into the roast ad-libs
MEME_THEMES=missing free throws|the guy who never passes|showing up late|ball don't lie|pickup game egos|leg day excuses

# ----- Accountability enforcer (calls out non-voters / non-payers by @-mention) -----

# Master toggle for the whole accountability layer (default: true)
ACCOUNTABILITY_ENABLED=true

# Vote nudges: a few random pokes through the voting window; each calls out 1 non-voter.
# Default Tue 15:00, Wed 12:00, Thu 10:00 (pipe-separated crons, evaluated in TIMEZONE)
NUDGE_CRONS=0 15 * * 2|0 12 * * 3|0 10 * * 4

# Pay nags: keep nagging non-payers until they pay; each roasts 1–2 unpaid voters.
# Default Fri 18:00, Sat 11:00, Sun 11:00 (pipe-separated crons, evaluated in TIMEZONE)
PAYNAG_CRONS=0 18 * * 5|0 11 * * 6|0 11 * * 0
